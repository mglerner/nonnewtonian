# Copy to /etc/nnp-backup.env on the server, then: chown root:root, chmod 600.
# This file holds secrets (the restic passphrase and B2 keys).
#
# IMPORTANT: also store the restic passphrase in your password manager. It is
# the ONLY key to the backups -- if the server dies and the passphrase died
# with it, the off-site copies are unrecoverable ciphertext.

# --- what to back up ---
NNP_DB=/var/lib/nnp/app.db
NNP_PHOTOS=/var/lib/nnp/photos
NNP_BACKUP_STAGING=/var/lib/nnp/backup-staging

# --- where to back up (Backblaze B2). Any restic backend works; swap this line. ---
RESTIC_REPOSITORY=b2:YOUR_BUCKET_NAME:nnp
B2_ACCOUNT_ID=your_b2_keyID
B2_ACCOUNT_KEY=your_b2_applicationKey

# --- the encryption key: EITHER set it inline ... ---
# RESTIC_PASSWORD=choose-a-long-random-passphrase
# --- ... OR point at a root-only file (chmod 600): ---
RESTIC_PASSWORD_FILE=/etc/nnp-backup/restic-pass

# --- retention (optional; these are the defaults) ---
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
